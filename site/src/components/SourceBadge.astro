---
import type { ImageSource } from "../data/full-catalog";

interface Props {
  source: ImageSource;
}

const { source } = Astro.props;
---

{
  source === "integer" ? (
    <span class="inline-flex items-center gap-1 text-[0.65rem] leading-none px-2 py-1 rounded-full bg-green-950/30 text-green-400 border border-green-800/40 uppercase font-semibold tracking-wide">
      <span class="w-1.5 h-1.5 rounded-full bg-green-400" />
      Zero-CVE
    </span>
  ) : (
    <span class="inline-flex items-center gap-1 text-[0.65rem] leading-none px-2 py-1 rounded-full bg-verity-surface text-verity-nucleus border border-verity-orbit/30 uppercase font-semibold tracking-wide">
      <span class="w-1.5 h-1.5 rounded-full bg-verity-nucleus" />
      Patched
    </span>
  )
}
