---
/**
 * Compact severity badges for catalog list view.
 * Shows small colored badges with counts for each severity level.
 */
import type { VulnSummary } from "../lib/catalog";
import { SEVERITY_ORDER } from "../lib/severity";

interface Props {
  summary: VulnSummary;
  compact?: boolean;
}

const { summary, compact = false } = Astro.props;
const hasVulns = summary.total > 0;

// Severity badge styles - compact colored pills
const BADGE_STYLES: Record<string, string> = {
  CRITICAL: "bg-red-950/60 text-red-400 border-red-800/50",
  HIGH: "bg-orange-950/60 text-orange-400 border-orange-800/50",
  MEDIUM: "bg-yellow-950/60 text-yellow-400 border-yellow-800/50",
  LOW: "bg-green-950/60 text-green-400 border-green-800/50",
  UNKNOWN: "bg-verity-surface text-verity-text-muted border-verity-border",
};

// Short labels for compact mode
const SHORT_LABELS: Record<string, string> = {
  CRITICAL: "C",
  HIGH: "H",
  MEDIUM: "M",
  LOW: "L",
  UNKNOWN: "?",
};
---

{
  hasVulns ? (
    <div class="flex items-center gap-0.5">
      {SEVERITY_ORDER.map((sev) => {
        const count = summary.severityCounts[sev] || 0;
        if (count === 0) return null;
        const style = BADGE_STYLES[sev];
        return (
          <span
            class={`text-[0.6rem] leading-none px-1 py-0.5 rounded border font-medium ${style}`}
            title={`${count} ${sev}`}
          >
            {compact ? SHORT_LABELS[sev] : count}
          </span>
        );
      })}
    </div>
  ) : (
    <span class="text-[0.6rem] leading-none px-1.5 py-0.5 rounded bg-green-950/30 text-green-400 border border-green-800/40">
      0 CVE
    </span>
  )
}
