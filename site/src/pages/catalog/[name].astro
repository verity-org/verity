---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CopyButton from "../../components/CopyButton.astro";
import SupplyChainBadges from "../../components/SupplyChainBadges.astro";
import SeverityBreakdown from "../../components/SeverityBreakdown.astro";
import VulnTable from "../../components/VulnTable.astro";
import { fullCatalog, upstreamPath, stripTag, REGISTRY } from "../../data/full-catalog";
import type { FullCatalogImage, FullCatalogCategory } from "../../data/full-catalog";
import SourceBadge from "../../components/SourceBadge.astro";
import { catalog } from "../../lib/catalog";
import type { SiteImage, IntegerImage, IntegerVersion, IntegerVariant } from "../../lib/catalog";
import { getIntegerImage } from "../../data/integer-catalog";

interface IntegerDataWithRegistry extends IntegerImage {
  registry: string;
}

interface CatalogPageProps {
  image: FullCatalogImage;
  category: FullCatalogCategory;
  scanData?: SiteImage;
  integerData?: IntegerDataWithRegistry;
  hardenedEquivalent?: string;
}

function isEolPassed(eolDateStr: string): boolean {
  const [year, month, day] = eolDateStr.split("-").map(Number);
  const eolDate = new Date(Date.UTC(year, month - 1, day));
  const today = new Date();
  const todayUtc = new Date(Date.UTC(today.getFullYear(), today.getMonth(), today.getDate()));
  return todayUtc >= eolDate;
}

function sortVersionsLatestFirst(versions: IntegerVersion[]): IntegerVersion[] {
  return [...versions].sort((a, b) => {
    if (a.latest && !b.latest) return -1;
    if (!a.latest && b.latest) return 1;
    return b.version.localeCompare(a.version, undefined, { numeric: true });
  });
}

function getDefaultVariant(variants: IntegerVariant[]): IntegerVariant | undefined {
  return variants.find((v) => v.type === "default") ?? variants[0];
}

function getUniqueVariantTypes(variants: IntegerVariant[]): string[] {
  return [...new Set(variants.map((v) => v.type))];
}

export async function getStaticPaths() {
  const paths: { params: { name: string }; props: CatalogPageProps }[] = [];

  // Pre-compute set of integer image names for upgrade banner logic
  const integerImageNames = new Set(
    fullCatalog.flatMap((cat) =>
      cat.images.filter((img) => img.source === "integer").map((img) => img.name)
    )
  );

  for (const category of fullCatalog) {
    for (const image of category.images) {
      const scanData = catalog.images?.find((ci) => {
        const name = ci.patchedRef?.split("/").pop()?.split(":")[0] ?? "";
        return name === image.name;
      });

      // Fetch integer version data for integer source images
      let integerData: IntegerImage | undefined;
      if (image.source === "integer") {
        integerData = await getIntegerImage(image.name);
      }

      // Check if copa image has a hardened (integer) equivalent
      let hardenedEquivalent: string | undefined;
      if (image.source === "copa" && integerImageNames.has(image.name)) {
        hardenedEquivalent = image.name;
      }

      paths.push({
        params: { name: image.name },
        props: { image, category, scanData, integerData, hardenedEquivalent },
      });
    }
  }

  return paths;
}

const { image, category, scanData, integerData, hardenedEquivalent } = Astro.props;
const base = import.meta.env.BASE_URL;
const pullRef = scanData?.patchedRef
  ? stripTag(scanData.patchedRef)
  : `${REGISTRY}/${upstreamPath(image)}`;
const dockerPull = `docker pull ${pullRef}`;

const fixed = scanData ? scanData.beforeVulns.total - scanData.afterVulns.total : 0;
const remaining = scanData?.afterVulns.total ?? 0;
const pendingVulns = scanData?.vulnerabilities.filter((v) => v.fixedVersion) ?? [];
const awaitingFixVulns = scanData?.vulnerabilities.filter((v) => !v.fixedVersion) ?? [];

const sortedVersions = integerData ? sortVersionsLatestFirst(integerData.versions) : [];
---

<BaseLayout title={`${image.label ?? image.name} — Verity`}>
  <nav class="text-sm text-verity-text-secondary mb-6">
    <a href={base} class="hover:text-verity-nucleus transition-colors">Home</a>
    <span class="mx-1">/</span>
    <span class="text-verity-text-secondary">Catalog</span>
    <span class="mx-1">/</span>
    <span class="text-verity-text-primary">{image.label ?? image.name}</span>
  </nav>

  <div class="mb-6">
    <div class="flex items-center gap-3 flex-wrap mb-2">
      <h1 class="text-2xl font-bold font-mono text-verity-text-primary">
        {image.label ?? image.name}
      </h1>
      <SourceBadge source={image.source} />
      {
        image.variants?.includes("fips") && (
          <span class="text-xs px-2 py-0.5 rounded-full bg-amber-950/40 text-amber-400 border border-amber-800/50 uppercase font-semibold">
            FIPS
          </span>
        )
      }
    </div>
    <div class="text-sm text-verity-text-secondary">
      {category.label}
      {
        image.upstream && (
          <span class="text-verity-text-muted ml-2">
            from <code class="text-xs">{image.upstream}</code>
          </span>
        )
      }
    </div>
  </div>

  <div class="bg-verity-surface border border-verity-nucleus/30 rounded-lg p-4 mb-6">
    <div class="text-xs text-verity-nucleus uppercase tracking-wide font-medium mb-1">
      Pull Reference
    </div>
    <div class="font-mono text-sm break-all text-verity-text-primary mb-2">{pullRef}</div>
    <div
      class="bg-verity-void border border-verity-border rounded p-3 font-mono text-xs text-verity-text-primary overflow-x-auto mb-2"
    >
      {dockerPull}
    </div>
    <CopyButton text={dockerPull} />
  </div>

  {
    image.variants && image.variants.length > 0 && (
      <div class="bg-verity-surface border border-verity-border rounded-lg p-4 mb-6">
        <div class="text-xs text-verity-text-secondary uppercase tracking-wide font-medium mb-3">
          Available Variants
        </div>
        <div class="flex flex-wrap gap-2">
          {image.variants.map((variant) => (
            <div class="flex items-center gap-2 px-3 py-2 rounded-lg border border-verity-border bg-verity-void/50">
              <span class="text-sm text-verity-text-primary font-medium">{variant}</span>
              <code class="text-xs text-verity-text-muted">
                {pullRef}:{variant}
              </code>
            </div>
          ))}
        </div>
      </div>
    )
  }
  {
    integerData && sortedVersions.length > 0 && (
      <div class="bg-verity-surface border border-verity-border rounded-lg p-4 mb-6">
        <div class="text-xs text-verity-text-secondary uppercase tracking-wide font-medium mb-3">
          Available Versions
        </div>
        <div class="space-y-3">
          {sortedVersions.map((version) => {
            const isLatest = version.latest ?? false;
            const defaultVariant = getDefaultVariant(version.variants);
            const variantTypes = getUniqueVariantTypes(version.variants);
            return (
              <div class="flex items-start justify-between gap-4 p-3 rounded-lg border border-verity-border bg-verity-void/50">
                <div class="min-w-0 flex-1">
                  <div class="flex items-center gap-2 mb-1">
                    <span class="font-mono text-sm font-medium text-verity-text-primary">
                      {version.version}
                    </span>
                    {isLatest && (
                      <span class="text-xs px-1.5 py-0.5 rounded bg-green-950/40 text-green-400 border border-green-800/50 font-medium">
                        latest
                      </span>
                    )}
                    {version.eol && isEolPassed(version.eol) && (
                      <span class="text-xs px-1.5 py-0.5 rounded bg-amber-950/40 text-amber-400 border border-amber-800/50 font-medium">
                        EOL: {version.eol}
                      </span>
                    )}
                  </div>
                  <code class="text-xs text-verity-text-muted break-all">
                    {defaultVariant?.ref ??
                      `${integerData.registry || REGISTRY}/${image.name}:${version.version}`}
                  </code>
                </div>
                <div class="flex flex-wrap gap-1.5 shrink-0">
                  {variantTypes.map((type) => (
                    <span class="text-xs px-1.5 py-0.5 rounded border border-verity-border text-verity-text-secondary font-mono">
                      {type}
                    </span>
                  ))}
                </div>
              </div>
            );
          })}
        </div>
      </div>
    )
  }

  {
    image.source === "integer" ? (
      <div class="bg-verity-surface border border-verity-border rounded-lg p-4 mb-6">
        <div class="flex items-center gap-2 mb-2">
          <svg
            class="w-4 h-4 text-green-400"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2.5"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
            />
          </svg>
          <span class="text-sm font-medium text-green-400">Wolfi-Based Image</span>
        </div>
        <p class="text-sm text-verity-text-secondary">
          Built from scratch using
          <a
            href="https://github.com/wolfi-dev"
            class="text-verity-orbit hover:text-verity-nucleus underline"
            target="_blank"
            rel="noopener noreferrer"
          >
            Wolfi
          </a>
          packages. Contains only the minimum packages needed to run — no shell, no package manager,
          minimal attack surface by design.
        </p>
      </div>
    ) : (
      <div class="bg-verity-surface border border-verity-border rounded-lg p-4 mb-6">
        <div class="flex items-center gap-2 mb-2">
          <svg
            class="w-4 h-4 text-verity-nucleus"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2.5"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
            />
          </svg>
          <span class="text-sm font-medium text-verity-nucleus">Copa-Patched Image</span>
        </div>
        <p class="text-sm text-verity-text-secondary">
          Patched in-place from the upstream image using
          <a
            href="https://github.com/project-copacetic/copacetic"
            class="text-verity-orbit hover:text-verity-nucleus underline"
            target="_blank"
            rel="noopener noreferrer"
          >
            Copa
          </a>
          . OS-level vulnerabilities are fixed without rebuilding — same layers, same behavior,
          fewer CVEs.
        </p>
      </div>
    )
  }

  {
    hardenedEquivalent && (
      <div class="bg-green-950/20 border border-green-800/40 rounded-lg p-4 mb-6">
        <div class="flex items-start gap-3">
          <svg
            class="w-5 h-5 text-green-400 shrink-0 mt-0.5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"
            />
          </svg>
          <div>
            <p class="text-sm font-medium text-green-400 mb-1">Wolfi-Based Alternative Available</p>
            <p class="text-sm text-verity-text-secondary">
              A hardened version of this image built from scratch with Wolfi is available with
              minimal attack surface.
            </p>
            <a
              href={`${base}catalog/${hardenedEquivalent}/?filter=integer`}
              class="inline-flex items-center gap-1.5 mt-2 text-sm font-medium text-green-400 hover:text-green-300 transition-colors"
            >
              View hardened version
              <svg
                class="w-4 h-4"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"
                />
              </svg>
            </a>
          </div>
        </div>
      </div>
    )
  }

  {
    scanData && (
      <div class="mb-6">
        <SupplyChainBadges artifactRef={scanData.patchedRef} />
      </div>
    )
  }

  {
    image.source === "copa" && (
      <div class="mb-8">
        <h2 class="text-lg font-semibold mb-1 text-verity-text-primary">Vulnerability Scan</h2>
        {!scanData ? (
          <div class="flex items-center gap-2 p-3 bg-verity-surface border border-verity-border rounded-lg">
            <svg
              class="w-5 h-5 text-verity-text-muted shrink-0"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9 5.25h.008v.008H12v-.008z"
              />
            </svg>
            <p class="text-sm text-verity-text-muted">
              Scan data not yet available for this image.
            </p>
          </div>
        ) : scanData.beforeVulns.total > 0 ? (
          <>
            <p class="text-sm text-verity-text-muted mb-3">
              {fixed > 0 ? (
                <>
                  Found {scanData.beforeVulns.total} vulnerabilit
                  {scanData.beforeVulns.total === 1 ? "y" : "ies"} in the original image.
                  <span class="text-verity-nucleus font-medium"> {fixed} fixed by Copa.</span>
                  {remaining > 0 && (
                    <span class="text-verity-text-secondary">
                      {" "}
                      {remaining} remaining after patching.
                    </span>
                  )}
                </>
              ) : (
                <>
                  Found {scanData.beforeVulns.total} vulnerabilit
                  {scanData.beforeVulns.total === 1 ? "y" : "ies"} — none have upstream fixes
                  available.
                </>
              )}
            </p>
            <SeverityBreakdown summary={scanData.beforeVulns} />
          </>
        ) : (
          <div class="flex items-center gap-2 p-3 bg-green-950/20 border border-green-800/40 rounded-lg">
            <svg
              class="w-5 h-5 text-green-400 shrink-0"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
              />
            </svg>
            <p class="text-sm text-green-400">No vulnerabilities detected in the latest scan.</p>
          </div>
        )}
      </div>
    )
  }

  {
    pendingVulns.length > 0 && (
      <section class="mb-8">
        <h2 class="text-lg font-semibold mb-1 text-verity-text-primary">
          Fix available — pending patch
        </h2>
        <p class="text-sm text-verity-text-muted mb-3">
          These vulnerabilities have upstream fixes but could not be automatically patched.
        </p>
        <VulnTable vulnerabilities={pendingVulns} />
      </section>
    )
  }

  {
    awaitingFixVulns.length > 0 && (
      <section class="mb-8">
        <h2 class="text-lg font-semibold mb-1 text-verity-text-primary">Awaiting upstream fix</h2>
        <p class="text-sm text-verity-text-muted mb-3">
          No fix is available yet for these vulnerabilities.
        </p>
        <VulnTable vulnerabilities={awaitingFixVulns} />
      </section>
    )
  }

  <div class="grid grid-cols-2 gap-4 mt-8 pt-6 border-t border-verity-border text-sm">
    <div>
      <div class="text-verity-text-muted mb-1">Source</div>
      <div class="text-verity-text-primary">
        {image.source === "integer" ? "Wolfi (from-source rebuild)" : "Copa (in-place patch)"}
      </div>
    </div>
    <div>
      <div class="text-verity-text-muted mb-1">Platforms</div>
      <div class="text-verity-text-primary">linux/amd64, linux/arm64</div>
    </div>
    <div>
      <div class="text-verity-text-muted mb-1">Registry</div>
      <div class="text-verity-text-primary font-mono text-xs">{REGISTRY}</div>
    </div>
    {
      image.upstream && (
        <div>
          <div class="text-verity-text-muted mb-1">Upstream</div>
          <div class="text-verity-text-primary font-mono text-xs">{image.upstream}</div>
        </div>
      )
    }
  </div>
</BaseLayout>
